# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Copy this file to .env and fill in your values.
# The project reads these via os.getenv() — no dotenv library required,
# but you can use `python-dotenv` or `direnv` if you prefer.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama"     → use a local Ollama server (free, no API key needed)
# "openrouter" → use OpenRouter / OpenAI-compatible endpoint (paid)
LLM_PROVIDER=ollama


# ── Ollama settings (used when LLM_PROVIDER=ollama) ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2


# ── OpenRouter / OpenAI settings (used when LLM_PROVIDER=openrouter) ─────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Or use OpenAI directly:
# OPENAI_API_KEY=sk-...

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini


# ── Qdrant settings ───────────────────────────────────────────────────────────
# Leave blank to use the in-memory backend (default, no server needed).
# For a persistent local server:  QDRANT_URL=http://localhost:6333
# For Qdrant Cloud:               QDRANT_URL=https://<cluster-id>.cloud.qdrant.io
#                                 QDRANT_API_KEY=<your-qdrant-cloud-key>
QDRANT_URL=
QDRANT_API_KEY=


# ── Benchmark pricing overrides ───────────────────────────────────────────────
# Per-million-token prices in USD. Leave blank to use the built-in model
# defaults (see benchmark.py PRICING_PER_MILLION table).
INPUT_PRICE_PER_MILLION=
OUTPUT_PRICE_PER_MILLION=


# ── Cache threshold ───────────────────────────────────────────────────────────
# Cosine-similarity threshold for a cache hit. Range: 0.0–1.0
# Recommended: 0.90–0.95.  Too low → false positives. Too high → no savings.
SIMILARITY_THRESHOLD=0.92
